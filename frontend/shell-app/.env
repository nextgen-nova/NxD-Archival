# ══════════════════════════════════════════════════════
#  Shell App — .env
#  All values are soft-coded. Change any without touching
#  source code, then run:  npm run build
# ══════════════════════════════════════════════════════

# ── Ports ─────────────────────────────────────────────
PORT=3000

USER_MFE_URL=http://localhost:3001
SEARCH_MFE_URL=http://localhost:3002
PROFILE_MFE_URL=http://localhost:3003
REPORTS_MFE_URL=http://localhost:3004

REACT_APP_API_BASE_URL=http://localhost:8080

# ── Backend API ───────────────────────────────────────

# ── Branding / Theme (all CSS vars driven by these) ───
REACT_APP_APP_NAME=SWIFT
REACT_APP_APP_SUBTITLE=Financial Messaging Intelligence
REACT_APP_LOGO_FILE=nxd-logo.svg
REACT_APP_LOGO_BG=transparent

REACT_APP_FONT=-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif
REACT_APP_HEADING_COLOR=#0f172a
REACT_APP_PRIMARY_COLOR=#3b82f6
REACT_APP_BACKGROUND_COLOR=#f8fafc
REACT_APP_ACCENT_COLOR=#6366f1
REACT_APP_TEXT_COLOR=#475569
